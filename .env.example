# Firebase public config — safe in frontend (VITE_ prefix = bundled into build)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# authDomain controls where Firebase sends the OAuth redirect.
# Use the same hostname as your deployed app:
VITE_FIREBASE_AUTH_DOMAIN=your-project.web.app
# Alternative: VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AI endpoint — the ONLY AI-related value allowed in the frontend.
# Default: /api/ai (Cloudflare Pages Function, co-deployed with the site — no extra config).
# Override only if you are using a standalone Cloudflare Worker instead:
# VITE_AI_WORKER_URL=https://your-worker.your-subdomain.workers.dev
#
# In local dev, leave this unset.  /api/ai won't exist on localhost, so AI calls
# fail gracefully and the rest of the app works normally offline.
# For full local AI testing, run: wrangler pages dev dist  (with GROQ_API_KEY in .dev.vars)

# ── FORBIDDEN — do NOT add these ─────────────────────────────────────────────
# VITE_GROQ_API_KEY=       ← bundled into browser JS — anyone can read it
# VITE_GEMINI_API_KEY=     ← same problem
# VITE_OPENROUTER_API_KEY= ← same problem
#
# AI provider keys belong ONLY in Cloudflare Pages encrypted secrets:
#   Dashboard → Pages project → Settings → Environment Variables → Add secret
#   Variable name: GROQ_API_KEY  (mark as "Secret")
